# ── Supabase (OBLIGATORIO — datos en la nube) ─────────────────
# Crea proyecto en https://supabase.com → Settings → API
VITE_SUPABASE_URL=https://TU_PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=tu_anon_key

# Ejecuta el SQL en supabase/migrations/001_initial_schema.sql
# (Supabase → SQL Editor → New query → pegar → Run)

# ── football-data.org (opcional) ────────────────────────────────
VITE_FOOTBALL_DATA_ENABLED=true
FOOTBALL_DATA_TOKEN=

# ── API-Football (opcional) ─────────────────────────────────────
VITE_API_FOOTBALL_KEY=
API_FOOTBALL_KEY=

# ── Vercel ──────────────────────────────────────────────────────
# Añade las mismas variables en Project → Settings → Environment Variables
# Redeploy después de cambiarlas
