# ── Local (.env) ──────────────────────────────────────────────
# Copia este archivo a .env y rellena los valores.

# football-data.org (RECOMENDADO — gratis, resultados + clasificación)
# Registro: https://www.football-data.org/client/register
VITE_FOOTBALL_DATA_TOKEN=
VITE_FOOTBALL_DATA_COMP=WC
VITE_FOOTBALL_DATA_SEASON=2026
VITE_FD_POLL_MS=180000

# API-Football (opcional, en vivo — plan de pago para WC 2026)
VITE_API_FOOTBALL_KEY=
VITE_API_FOOTBALL_LEAGUE=1
VITE_API_FOOTBALL_SEASON=2026
VITE_LIVE_POLL_MS=30000

# ── Vercel (producción) ───────────────────────────────────────
# 1. Sube el repo a GitHub y conéctalo en https://vercel.com/new
# 2. Vercel detecta Vite automáticamente (vercel.json incluido)
# 3. En Project → Settings → Environment Variables añade:
#
#    VITE_FOOTBALL_DATA_ENABLED=true  → activa sync sin exponer token en el bundle
#    VITE_FOOTBALL_DATA_TOKEN         → alternativa: activa sync + token en build
#    FOOTBALL_DATA_TOKEN              → token real en servidor (recomendado en prod)
#    VITE_API_FOOTBALL_KEY      → opcional
#    API_FOOTBALL_KEY           → opcional, solo servidor
#
# 4. Redeploy tras cambiar variables de entorno
#
# Las APIs externas pasan por /api/* (proxy serverless); el token no viaja
# desde el navegador en producción.
